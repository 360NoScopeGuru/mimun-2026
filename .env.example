# Local dev: a regular Postgres connection string.
# Production (Vercel): use Neon's pooled connection string (the one with
# "-pooler" in the hostname) so serverless function instances don't exhaust
# Postgres' connection limit.
DATABASE_URL=postgres://user:password@localhost:5432/mimun_dev

# ── AI features (parliamentarian, draft feedback, session summaries) ──────────
# Optional. With neither key set, every AI feature hides itself gracefully.
# Both providers are OpenAI-compatible; requests fail over in AI_PROVIDER_ORDER
# so when one free tier rate-limits, the next answers.
OPENROUTER_API_KEY=
NVIDIA_NIM_API_KEY=
# Comma-separated priority order; unknown ids sink to the end.
AI_PROVIDER_ORDER=openrouter,nvidia
# Model slugs are env-overridable because free slugs change often. If a default
# starts returning 404/429, swap the slug here without touching code.
OPENROUTER_MODEL=openai/gpt-oss-120b:free
NVIDIA_NIM_MODEL=meta/llama-3.1-8b-instruct
# Optional base-URL overrides (defaults target each provider's public API):
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
